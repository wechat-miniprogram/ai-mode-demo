<view class="ae-page">
  <view class="ae-header" style="padding-top: {{headerPaddingTop}}rpx;">
    <view class="ae-title">收货地址</view>
    <view class="ae-sub">保存后将自动继续下单流程</view>
  </view>

  <view class="ae-form">
    <view class="ae-field">
      <view class="ae-field-label">收货人</view>
      <input
        class="ae-input"
        placeholder="请输入收货人姓名"
        placeholder-class="ae-placeholder"
        value="{{name}}"
        bindinput="onInputName"
        maxlength="20"
      />
    </view>

    <view class="ae-field">
      <view class="ae-field-label">手机号</view>
      <input
        class="ae-input"
        type="number"
        placeholder="请输入 11 位手机号"
        placeholder-class="ae-placeholder"
        value="{{phone}}"
        bindinput="onInputPhone"
        maxlength="11"
      />
    </view>

    <view class="ae-field">
      <view class="ae-field-label">详细地址</view>
      <textarea
        class="ae-textarea"
        placeholder="省市区及门牌号"
        placeholder-class="ae-placeholder"
        value="{{detail}}"
        bindinput="onInputDetail"
        maxlength="120"
        auto-height
      />
    </view>
  </view>

  <view class="ae-footer safe-area-bottom">
    <view
      class="ae-submit {{canSubmit ? '' : 'ae-submit-disabled'}}"
      hover-class="{{canSubmit ? 'btn-hover' : ''}}"
      bind:tap="onTapSubmit"
    >
      <text class="ae-submit-text">保存并继续下单</text>
    </view>
  </view>
</view>
