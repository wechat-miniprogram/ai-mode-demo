page {
  background-color: #FFF8F0;
  height: 100%;
}

.ae-page {
  min-height: 100%;
  display: flex;
  flex-direction: column;
  background: linear-gradient(180deg, #FFF8F0 0%, #F5EFE6 100%);
}

.ae-header {
  padding: 36rpx 36rpx 20rpx;
}

.ae-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #2A1810;
}

.ae-sub {
  font-size: 24rpx;
  color: #A89180;
  margin-top: 8rpx;
}

.ae-form {
  padding: 12rpx 24rpx;
}

.ae-field {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 28rpx 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(92, 58, 33, 0.05);
}

.ae-field-label {
  font-size: 24rpx;
  color: #8B5E3C;
  margin-bottom: 12rpx;
  letter-spacing: 1rpx;
}

.ae-input {
  font-size: 30rpx;
  color: #2A1810;
  width: 100%;
  padding: 8rpx 0;
}

.ae-textarea {
  font-size: 30rpx;
  color: #2A1810;
  width: 100%;
  min-height: 100rpx;
  line-height: 1.5;
}

.ae-placeholder {
  color: #BFB0A0;
  font-size: 28rpx;
}

.ae-footer {
  margin-top: auto;
  padding: 24rpx 36rpx;
}

.safe-area-bottom {
  padding-bottom: calc(env(safe-area-inset-bottom) + 24rpx);
}

.ae-submit {
  padding: 26rpx 0;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #8B5E3C 0%, #5C3A21 100%);
  text-align: center;
}

.ae-submit-disabled {
  background: #D6C7B5;
}

.btn-hover {
  opacity: 0.85;
}

.ae-submit-text {
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
}

/* ========== 暗黑模式 ========== */
@media (prefers-color-scheme: dark) {
  page {
    background-color: #121212;
  }
  .ae-page {
    background: linear-gradient(180deg, #121212 0%, #1A1510 100%);
  }
  .ae-title {
    color: #E8E0D8;
  }
  .ae-sub {
    color: #7A6E62;
  }
  .ae-field {
    background: #1E1E1E;
    box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.2);
  }
  .ae-field-label {
    color: #D4A574;
  }
  .ae-input {
    color: #E8E0D8;
  }
  .ae-textarea {
    color: #E8E0D8;
  }
  .ae-placeholder {
    color: #5A5048;
  }
  .ae-submit {
    background: linear-gradient(135deg, #A07050 0%, #7A5030 100%);
  }
  .ae-submit-disabled {
    background: #3E3228;
  }
}
