<view class="ss-card">
  <view class="ss-header">
    <view class="ss-title">{{storeName || '正在定位门店...'}}</view>
    <view wx:if="{{distance}}" class="ss-distance">{{distance}}</view>
  </view>

  <view wx:if="{{address}}" class="ss-addr">{{address}}</view>

  <view class="ss-live">
    <view class="ss-live-item">
      <view class="ss-live-label">当前排队</view>
      <view class="ss-live-value">
        <text class="ss-live-num">{{queueText}}</text>
        <text class="ss-live-unit">杯</text>
      </view>
    </view>
    <view class="ss-live-divider"></view>
    <view class="ss-live-item">
      <view class="ss-live-label">预计出杯</view>
      <view class="ss-live-value">
        <text class="ss-live-num">{{etaText}}</text>
        <text class="ss-live-unit">分钟</text>
      </view>
    </view>
  </view>

  <view class="ss-foot">
    <view class="ss-update">
      <text wx:if="{{status === 'loading'}}">正在刷新...</text>
      <text wx:else>实时 · 更新于 {{lastUpdate}}</text>
    </view>
    <view class="ss-refresh" hover-class="ss-refresh-hover" bind:tap="onTapRefresh">刷新</view>
  </view>
</view>
