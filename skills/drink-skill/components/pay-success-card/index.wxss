.ps-card {
  background: linear-gradient(180deg, #FFFFFF 0%, #FFF8F0 100%);
  border-radius: 28rpx;
  padding: 36rpx 28rpx;
  box-shadow: 0 6rpx 24rpx rgba(92, 58, 33, 0.08);
  box-sizing: border-box;
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.ps-badge {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #66BB6A 0%, #2E7D32 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 20rpx rgba(46, 125, 50, 0.3);
  margin-bottom: 20rpx;
}

.ps-check {
  color: #FFFFFF;
  font-size: 56rpx;
  font-weight: 700;
  line-height: 1;
}

.ps-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #2A1810;
  letter-spacing: 2rpx;
}

.ps-amount {
  font-size: 60rpx;
  font-weight: 800;
  color: #5C3A21;
  margin-top: 10rpx;
  letter-spacing: 2rpx;
}

.ps-info {
  width: 100%;
  margin-top: 24rpx;
  padding: 18rpx 20rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
}

.ps-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8rpx 0;
}

.ps-label {
  font-size: 24rpx;
  color: #A89180;
}

.ps-value {
  font-size: 24rpx;
  color: #2A1810;
  font-weight: 500;
  max-width: 60%;
  text-align: right;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.ps-mono {
  font-family: monospace;
  font-size: 22rpx;
}

.ps-tip {
  margin-top: 20rpx;
  font-size: 22rpx;
  color: #8B5E3C;
  letter-spacing: 1rpx;
}

/* ========== 暗黑模式 ========== */
@media (prefers-color-scheme: dark) {
  .ps-card {
    background: linear-gradient(180deg, #1E1E1E 0%, #1A1510 100%);
    box-shadow: 0 6rpx 24rpx rgba(0, 0, 0, 0.3);
  }
  .ps-title {
    color: #E8E0D8;
  }
  .ps-amount {
    color: #D4A574;
  }
  .ps-info {
    background: #2A2A2A;
  }
  .ps-label {
    color: #7A6E62;
  }
  .ps-value {
    color: #E8E0D8;
  }
  .ps-tip {
    color: #D4A574;
  }
}
