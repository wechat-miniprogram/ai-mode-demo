<view class="ps-card">
  <view class="ps-badge">
    <view class="ps-check">✓</view>
  </view>
  <view class="ps-title">支付成功</view>
  <view class="ps-amount">¥{{paidAmount}}</view>

  <view class="ps-info">
    <view wx:if="{{drinkName}}" class="ps-row">
      <text class="ps-label">商品</text>
      <text class="ps-value">{{drinkName}}</text>
    </view>
    <view wx:if="{{specText}}" class="ps-row">
      <text class="ps-label">规格</text>
      <text class="ps-value">{{specText}}</text>
    </view>
    <view class="ps-row">
      <text class="ps-label">订单号</text>
      <text class="ps-value ps-mono">{{orderId}}</text>
    </view>
    <view wx:if="{{payTimeText}}" class="ps-row">
      <text class="ps-label">支付时间</text>
      <text class="ps-value">{{payTimeText}}</text>
    </view>
  </view>

  <view class="ps-tip">预计 20 分钟内出杯，感谢您的订单 ☕</view>
</view>
