.oc-card {
  background: #FFFFFF;
  border-radius: 28rpx;
  padding: 20rpx;
  box-shadow: 0 6rpx 24rpx rgba(92, 58, 33, 0.08);
  box-sizing: border-box;
  width: 100%;
}

.oc-header {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.oc-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #2A1810;
}

.oc-order-id {
  font-size: 20rpx;
  color: #A89180;
  font-family: monospace;
}

.oc-addr {
  display: flex;
  align-items: center;
  padding: 12rpx;
  background: #FFF8F0;
  border-radius: 12rpx;
  margin-bottom: 10rpx;
}

.oc-addr-empty {
  background: #FFF4E6;
  border: 2rpx dashed #D9B78C;
}

.oc-addr-empty-title {
  font-size: 26rpx;
  color: #5C3A21;
  font-weight: 600;
}

.oc-addr-empty-sub {
  font-size: 22rpx;
  color: #A89180;
  margin-top: 4rpx;
}

.row-hover {
  opacity: 0.85;
}

.oc-addr-body {
  flex: 1;
  min-width: 0;
}

.oc-addr-top {
  display: flex;
  align-items: baseline;
}

.oc-addr-name {
  font-size: 26rpx;
  color: #2A1810;
  font-weight: 600;
}

.oc-addr-phone {
  font-size: 22rpx;
  color: #6B5544;
  margin-left: 14rpx;
}

.oc-addr-detail {
  font-size: 20rpx;
  color: #6B5544;
  margin-top: 2rpx;
  line-height: 1.3;
  overflow: hidden;
  -wx-line-clamp: 1;
}

.oc-edit-text {
  font-size: 22rpx;
  color: #8B5E3C;
  align-self: center;
  margin-left: 10rpx;
}

.oc-item {
  display: flex;
  align-items: center;
  padding: 8rpx 0;
}

.oc-img {
  width: 80rpx;
  height: 80rpx;
  border-radius: 12rpx;
  background-color: #F5EFE6;
  flex-shrink: 0;
}

.oc-item-info {
  flex: 1;
  margin-left: 16rpx;
  min-width: 0;
}

.oc-item-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #2A1810;
}

.oc-item-spec {
  font-size: 22rpx;
  color: #6B5544;
  margin-top: 4rpx;
}

.oc-item-price {
  font-size: 24rpx;
  color: #5C3A21;
  margin-top: 6rpx;
}

.oc-divider {
  height: 2rpx;
  background: #EDE3D4;
  margin: 10rpx 0;
}

.oc-summary {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.oc-summary-label {
  font-size: 26rpx;
  color: #6B5544;
}

.oc-summary-price {
  font-size: 38rpx;
  font-weight: 800;
  color: #5C3A21;
}

.oc-pay-btn {
  padding: 16rpx 0;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #8B5E3C 0%, #5C3A21 100%);
  text-align: center;
}

.btn-hover {
  opacity: 0.85;
}

.oc-pay-text {
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
}

.oc-hint {
  font-size: 24rpx;
  color: #6B5544;
  line-height: 1.5;
  padding: 20rpx 8rpx;
  text-align: center;
}

/* ========== 暗黑模式 ========== */
@media (prefers-color-scheme: dark) {
  .oc-card {
    background: #1E1E1E;
    box-shadow: 0 6rpx 24rpx rgba(0, 0, 0, 0.3);
  }
  .oc-title {
    color: #E8E0D8;
  }
  .oc-order-id {
    color: #7A6E62;
  }
  .oc-addr {
    background: #2A2218;
  }
  .oc-addr-empty {
    background: #2A2218;
    border-color: #4E3E2E;
  }
  .oc-addr-empty-title {
    color: #D4A574;
  }
  .oc-addr-empty-sub {
    color: #7A6E62;
  }
  .oc-addr-name {
    color: #E8E0D8;
  }
  .oc-addr-phone {
    color: #9E8E7E;
  }
  .oc-addr-detail {
    color: #9E8E7E;
  }
  .oc-edit-text {
    color: #D4A574;
  }
  .oc-img {
    background-color: #2A2A2A;
  }
  .oc-item-name {
    color: #E8E0D8;
  }
  .oc-item-spec {
    color: #9E8E7E;
  }
  .oc-item-price {
    color: #D4A574;
  }
  .oc-divider {
    background: #3E3228;
  }
  .oc-summary-label {
    color: #9E8E7E;
  }
  .oc-summary-price {
    color: #D4A574;
  }
  .oc-pay-btn {
    background: linear-gradient(135deg, #A07050 0%, #7A5030 100%);
  }
  .oc-hint {
    color: #9E8E7E;
  }
}

